{
	"name": "our-days",
	"description": "mood tracker or maybe a social media of moods?",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "npm run build && vite preview",
		"worker:dev": "wrangler dev",
		"check": "tsc && vite build && wrangler deploy --dry-run",

		"setup:local": "npm install && npm run db:init:local",
		"setup": "npm install && npm run db:init",

		"db:init:local": "wrangler d1 execute our-days-db --local --file=./schema.sql",
		"db:reset:local": "wrangler d1 execute our-days-db --local --file=./schema.sql --force",

		"db:init": "wrangler d1 execute our-days-db --file=./schema.sql",
		"db:reset": "wrangler d1 execute our-days-db --file=./schema.sql --force",

		"cf-typegen": "wrangler types",
		"lint": "eslint .",
		"deploy": "npm run build && wrangler deploy"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"hono": "^4.12.8",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"tailwindcss": "^4.2.2"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.30.2",
		"@eslint/js": "9.39.1",
		"@types/node": "^24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "5.8.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^6.0.0",
		"wrangler": "^4.76.0"
	}
}
